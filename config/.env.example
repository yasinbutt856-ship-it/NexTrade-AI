# MEXC API Credentials (required for live trading)
MEXC_API_KEY=your_mexc_api_key
MEXC_API_SECRET=your_mexc_api_secret

# Redis (required for bot operation)
REDIS_URL=redis://localhost:6379

# JWT Secret (required for auth)
JWT_SECRET=your-256-bit-jwt-secret

# Encryption Key (required for MEXC key storage)
ENCRYPTION_KEY=your-fernet-encryption-key

# Database (default: SQLite, override for PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./trading.db

# Dashboard (legacy — replaced by JWT auth)
DASHBOARD_PASSWORD=admin
DASHBOARD_SECRET=change-me-in-production

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
